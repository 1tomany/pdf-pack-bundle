{
    "name": "1tomany/pdf-pack-bundle",
    "description": "Symfony bundle for the 1tomany/pdf-pack library",
    "license": "MIT",
    "type": "symfony-bundle",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "keywords": [
        "ocr",
        "pdf",
        "pdf2img",
        "pdf2image",
        "pdf2text",
        "pdf2txt",
        "pdfinfo",
        "pdftoppm",
        "pdf to image",
        "pdf to text",
        "poppler",
        "xpdf"
    ],
    "require": {
        "php": ">=8.2",
        "1tomany/pdf-pack": "^0.6.4",
        "symfony/config": "^7.2|^8.0",
        "symfony/dependency-injection": "^7.2|^8.0",
        "symfony/http-kernel": "^7.2|^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.93",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "OneToMany\\PdfPackBundle\\": "src/"
        }
    },
    "scripts": {
        "fix": "./vendor/bin/php-cs-fixer fix",
        "stan": "./vendor/bin/phpstan",
        "test": "./vendor/bin/phpunit"
    },
    "authors": [
        {
            "name": "Vic Cherubini",
            "email": "vcherubini@gmail.com"
        }
    ],
    "config": {
        "sort-packages": true
    }
}
